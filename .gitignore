# On-demand upstream clones: never vendored, never committed.
.cache/

# Repo-local Extension.js telemetry dir.
.xdg-config/

# Generated run artifacts. baseline.json (tracked, at repo root) is the only
# state that persists between runs; everything under reports/ is regenerated.
reports/*
!reports/.gitkeep

# Build output (samples build in OS temp; this guards against stray local builds).
# Anchored to the repo root on purpose: vendored samples legitimately commit
# nested dist/build dirs upstream (e.g. chrome/_archive), and an unanchored
# pattern would shadow them from git while vendor.mjs --check still hashes them.
/dist/
/build/
/.extension/

node_modules/
.DS_Store
